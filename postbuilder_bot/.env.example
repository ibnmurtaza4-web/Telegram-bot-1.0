# ─── PostBuilder Bot - Mühit Dəyişənləri ───────────────────────────────────
# Bu faylı .env adına kopyalayın: cp .env.example .env

# Telegram Bot Token (@BotFather-dan alın)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Admin Telegram ID-ləri (vergüllə ayırın)
ADMIN_IDS=123456789,987654321

# Verilənlər bazası URL-i
# SQLite (sadə):
DATABASE_URL=sqlite+aiosqlite:///postbuilder.db
# PostgreSQL (güclü):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/postbuilder

# Texniki xidmət rejimi (true/false)
MAINTENANCE_MODE=false
